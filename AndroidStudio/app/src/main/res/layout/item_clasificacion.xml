<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_clasificacion.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Fila del equipo -->
    <LinearLayout
        android:id="@+id/filaEquipo"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <!-- Posición -->
        <TextView
            android:id="@+id/txtPuesto"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center" />

        <!-- Escudo -->
        <ImageView
            android:id="@+id/imgEscudo"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:scaleType="fitCenter"
            android:contentDescription="Escudo" />

        <!-- Nombre equipo -->
        <TextView
            android:id="@+id/txtNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Barcelona"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="4dp" />

        <!-- Estadísticas -->
        <TextView android:id="@+id/txtPJ" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtV" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtE" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtD" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtGF" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtGC" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <TextView android:id="@+id/txtDG" android:layout_width="28dp"
            android:layout_height="wrap_content" android:gravity="center"
            android:textColor="#CCCCCC" android:textSize="12sp" />

        <!-- Puntos (destacado) -->
        <TextView
            android:id="@+id/txtPuntos"
            android:layout_width="34dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Separador entre filas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F1F1F" />

</LinearLayout>