            android:tint="#FFFFFF"
            android:alpha="0.4"
            android:contentDescription="Comparar jugadores"/>

        <TextView
            android:id="@+id/badgeEA"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerVertical="true" android:layout_alignParentEnd="true"
            android:text="EA\nSPORTS" android:textColor="#FFFFFF" android:textSize="10sp"
            android:textStyle="bold" android:gravity="center"
            android:background="@drawable/bg_ea_badge" android:padding="6dp"/>
    </RelativeLayout>

