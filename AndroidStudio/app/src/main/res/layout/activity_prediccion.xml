<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootPrediccion"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <RelativeLayout
        android:id="@+id/headerPrediccion"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="#E2001A"
        android:padding="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:contentDescription="Atrás" />

        <TextView
            android:id="@+id/txtTituloPrediccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="PREDICCIÓN"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/txtLogoLigaPrediccion"
            android:layout_width="70dp"
            android:layout_height="42dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="LALIGA"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#111111"
            android:padding="6dp" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/headerEquiposPrediccion"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#111111">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgEscudoLocal"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="fitCenter"
                android:contentDescription="Local" />

            <TextView
                android:id="@+id/txtNombreLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtVsPrediccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textColor="#666666"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgEscudoVisitante"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="fitCenter"
                android:contentDescription="Visitante" />

            <TextView
                android:id="@+id/txtNombreVisitante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/separadorHeaderPrediccion"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333" />

    <ScrollView
        android:id="@+id/scrollPrediccion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <LinearLayout
            android:id="@+id/contenidoPrediccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/cardGanador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#111111"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txtTituloGanador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREDICCIÓN DEL PARTIDO"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/txtGanador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txtConsejo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtTituloProbabilidades"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROBABILIDADES"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/cardProbabilidades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#111111"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtPctLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#4FC3F7"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtLabelLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Local"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtPctEmpate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFC107"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtLabelEmpate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Empate"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtPctVisitante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#4CAF50"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtLabelVisitante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visitante"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutBarra"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/barraLocal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="45"
                    android:background="#4FC3F7" />

                <View
                    android:id="@+id/barraEmpate"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="25"
                    android:background="#FFC107" />

                <View
                    android:id="@+id/barraVisitante"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="30"
                    android:background="#4CAF50" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtTituloComparativa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPARATIVA (ÚLTIMOS 5 PARTIDOS)"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/contenedorComparativa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#111111"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtTituloGolesEsperados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOLES ESPERADOS"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/cardGolesEsperados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#111111"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtGolesLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtGolesLocalLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtSeparadorGoles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="#555555"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtGolesVisitante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtGolesVisitanteLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/txtTituloFormaReciente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FORMA RECIENTE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/cardFormaReciente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#111111"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layoutFormaLocal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center" />

                <View
                    android:id="@+id/separadorForma"
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#333333"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:id="@+id/layoutFormaVisitante"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtTituloH2H"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTORIAL CARA A CARA"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutH2H"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#111111"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/txtTituloOnceLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONCE PROBABLE - LOCAL"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <com.example.tfg.FieldView
                android:id="@+id/fieldViewLocal"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtTituloOnceVisitante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONCE PROBABLE - VISITANTE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <com.example.tfg.FieldView
                android:id="@+id/fieldViewVisitante"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>